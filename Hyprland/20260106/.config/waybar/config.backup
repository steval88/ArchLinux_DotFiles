{


  "layer": "top",
  "position": "top",
  "margin-top": 6,
  "margin-left": 6,
  "margin-right": 6,
  "spacing": 8,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  
  "hyprland/workspaces": {
    "all-outputs": true,
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true,
    "disable-scroll": false,
    "persistent_workspaces": { "*": [ "1","2","3","4","5" ] }
  },

  "modules-center": ["clock"],
  "modules-right": ["custom/power", "cpu", "memory", "pulseaudio", "network", "battery"],

  "custom/power": {
  "format": "",
  "tooltip": "Power",
  "on-click": "wlogout -p layer-shell"
  },

  "clock": {
    "format": " {:%H:%M  %d %b}"
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " muted",
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": "󰈀 {ifname}",
    "format-disconnected": " disconnected",
    "tooltip": true
  },

  "battery": {
    "format": "{capacity}% 󰁹",
    "format-time": "{H}:{M}",
    "states": {
      "warning": 30,
      "critical": 15
    }
  },

  "cpu": {
    "format": " {usage}%"
  },

  "memory": {
    "format": " {used:0.1f}G"
  }
}
